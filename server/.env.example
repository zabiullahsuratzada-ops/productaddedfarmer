# Copy this file to .env and fill in your values.
# Get these from https://developers.facebook.com/

# Your Facebook Page ID (numeric). Find it in Page Settings > About.
FACEBOOK_PAGE_ID=your_page_id_here

# Long-lived Page Access Token with permissions:
#   pages_read_engagement, instagram_basic, pages_show_list
# Generate at: Graph API Explorer or via Business Manager.
FACEBOOK_ACCESS_TOKEN=your_long_lived_page_access_token_here

# Optional: Port for the server (default 3000)
# PORT=3000
